---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
const isIconLikeImage = /(?:app[-_ ]?icon|icon|favicon)/i.test(data.img.src);
---

<a class="card" href={`/work/${id}`}>
	<span class="content">
		<span class="title">{data.title}</span>
		<span class="tags" aria-label="Tags">
			{data.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
		</span>
	</span>
	<span class="media">
		<Image
			class:list={{ 'icon-like': isIconLikeImage }}
			src={data.img}
			alt={data.img_alt || ''}
			widths={[144, 216, 288, 384, 544]}
			sizes="(min-width: 50em) min(16vw, 11rem), 8rem"
			loading="lazy"
			decoding="async"
		/>
	</span>
</a>

<style>
	.card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 7rem;
		grid-template-areas: 'content media';
		align-items: center;
		min-height: 10.5rem;
		padding: 1.25rem;
		gap: 1rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		font-weight: 500;
		transition: box-shadow var(--theme-transition);
	}

	.card:hover {
		box-shadow: var(--shadow-md);
	}

	.content {
		grid-area: content;
		display: flex;
		min-width: 0;
		flex-direction: column;
		justify-content: center;
		gap: 0.875rem;
	}

	.title {
		color: var(--gray-100);
		font-size: var(--text-lg);
		line-height: 1.05;
		overflow-wrap: anywhere;
	}

	.tags {
		display: none;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.tag {
		padding: 0.25rem 0.5rem;
		color: var(--gray-300);
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 999px;
		font-family: var(--font-body);
		font-size: 0.75rem;
		line-height: 1.1;
	}

	.media {
		grid-area: media;
		display: grid;
		width: 100%;
		aspect-ratio: 1;
		place-items: center;
		padding: 0.875rem;
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
	}

	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	img.icon-like {
		width: 100%;
		height: 100%;
		aspect-ratio: 1;
		object-fit: contain;
		background: transparent;
	}

	@media (min-width: 28em) {
		.card {
			grid-template-columns: minmax(0, 1fr) 8.5rem;
		}

		.tags {
			display: flex;
		}
	}

	@media (min-width: 50em) {
		.card {
			min-height: 16rem;
			grid-template-columns: minmax(0, 1fr) minmax(9.5rem, 42%);
			padding: 1.5rem;
			gap: 1.5rem;
			border-radius: 1.5rem;
		}

		.title {
			font-size: var(--text-2xl);
		}

		.media {
			max-width: 11.5rem;
			justify-self: end;
			padding: 1rem;
			border-radius: 1.25rem;
		}
	}
</style>
