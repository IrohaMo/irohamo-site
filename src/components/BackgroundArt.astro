<div id="p5-container"></div>

<!-- p5.js をCDNから読み込み -->
<script is:client src="https://cdn.jsdelivr.net/npm/p5@1.9.3/lib/p5.min.js"></script>

<!-- スケッチ本体 -->
<script is:client>
	const sketch = (p) => {
		const layers = [];
		const LAYER_COUNT = 3;

		// テーマ別のカラーパレット
		const palettes = {
			dark: [220, 250, 280, 320], // 青〜紫系
			light: [30, 180, 300], // 橙〜水色〜ピンク系
		};

		// 現在のテーマ判定
		const getTheme = () =>
			document.documentElement.classList.contains("theme-dark")
			? "dark"
			: "light";

		p.setup = () => {
			p.createCanvas(p.windowWidth, p.windowHeight);
			p.noStroke();
			p.colorMode(p.HSB, 360, 100, 100, 100);

			// 🟩 初期描画で真っ先に背景を1回塗る
			const isDark = document.documentElement.classList.contains("theme-dark");
			if (isDark) {
				p.background(0, 0, 8); // 真っ黒ではなく柔らかい黒
			} else {
				p.background(0, 0, 100); // 白背景
			}

			// 🟩 光レイヤーを初期化
			for (let i = 0; i < LAYER_COUNT; i++) {
				layers.push({
				hue: p.random(isDark ? [220, 250, 280, 320] : [30, 180, 300]),
				yoff: p.random(1000),
				amp: p.random(100, 220),
				alpha: p.random(6, 12),
				speed: p.random(0.0001, 0.0002),
				});
			}
		};

		p.draw = () => {
			const theme = getTheme();
			const colors = palettes[theme];

			// 背景
			if (theme === "dark") {
				p.fill(0, 0, 8, 10); // 深い黒寄り
			} else {
				p.fill(0, 0, 100, 10); // 白に近い
			}
			p.rect(0, 0, p.width, p.height);

			// 波レイヤー
			for (let l of layers) {
				// テーマに応じてランダムHueを設定（動的変化）
				if (p.frameCount % 300 === 0) {
					l.hue += 0.05; // 徐々に変化
					if (l.hue > 360) l.hue -= 360;
				}

				const hue = l.hue || p.random(colors);
				const sat = theme === "dark" ? 60 : 30;
				const bright = theme === "dark" ? 90 : 95;
				const alpha = l.alpha;

				p.fill(hue, sat, bright, alpha);

				p.beginShape();
				for (let x = 0; x <= p.width; x += 10) {
					const y =
					p.height / 2 +
					p.sin(x * 0.002 + l.yoff) * l.amp * 0.6 +
					p.noise(x * 0.002, p.frameCount * l.speed) * l.amp;
					p.vertex(x, y);
				}
				p.vertex(p.width, p.height);
				p.vertex(0, p.height);
				p.endShape(p.CLOSE);

				l.yoff += l.speed * 100;
			}

			// 上部グラデーション（光の霞）
			const g = p.drawingContext.createLinearGradient(
				0,
				0,
				0,
				p.height * 0.8
			);
			if (theme === "dark") {
				g.addColorStop(0, "hsla(250, 80%, 70%, 0.08)");
				g.addColorStop(1, "hsla(210, 60%, 5%, 0)");
			} else {
				g.addColorStop(0, "hsla(50, 90%, 95%, 0.1)");
				g.addColorStop(1, "hsla(200, 80%, 70%, 0)");
			}
			p.drawingContext.fillStyle = g;
			p.rect(0, 0, p.width, p.height);
		};

		p.windowResized = () => {
			p.resizeCanvas(p.windowWidth, p.windowHeight);
		};
	};

	new p5(sketch, "p5-container");
</script>

<style>
	#p5-container {
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}
	canvas {
		display: block;
		position: absolute;
		inset: 0;
	}
</style>
