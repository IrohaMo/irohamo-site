---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<div class="stack gap-20">
	<main class="wrapper about">
		<Hero
			title="About"
		/>

		<section>
			<h2 class="section-title">Background</h2>
			<div class="content">
				<p>
					早稲田大学と42Tokyoに在籍し、半導体工学を学びながら、UnityやSwiftなどによるネイティブアプリケーション開発、C言語での低レイヤープログラミングにも取り組んでいます。
				</p>
				<p>
					現在はiPadOS向け津軽三味線譜アプリ「ShamiScore」を開発しており、コードと音を結びつける実用的なツールづくりを目指しています。
				</p>
			</div>
		</section>
		<section>
			<h2 class="section-title">Education</h2>
			<div class="content">
				<p>早稲田大学基幹理工学部 在学中 / 42Tokyo 在籍中</p>
			</div>
		</section>
		<section>
			<h2 class="section-title">Skills</h2>
			<div class="content">
				<img src="/assets/icons/c-original.svg" width="50" height="50" alt="C" style="margin-right:10px;" />
				<img src="/assets/icons/swift-original.svg" width="50" height="50" alt="Swift" style="margin-right:10px;" />
				<img src="/assets/icons/javascript-original.svg" width="50" height="50" alt="JavaScript" style="margin-right:10px;" />
				<img src="/assets/icons/html5-original.svg" width="50" height="50" alt="HTML5" style="margin-right:10px;" />
				<img src="/assets/icons/css3-original.svg" width="50" height="50" alt="CSS3" style="margin-right:10px;" />
				<img src="/assets/icons/unity-original.svg" width="50" height="50" alt="Unity" style="margin-right:10px;" />
			</div>
		</section>
	</main>
</div>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 0;
		border-radius: 0;
		box-shadow: none;
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
