<div id="p5-container"></div>

<!-- p5.js をCDNから読み込み -->
<script is:client src="https://cdn.jsdelivr.net/npm/p5@1.9.3/lib/p5.min.js"></script>

<!-- スケッチ本体 -->
<script is:client>

	const sketch = (p) => {
		const layers = [];
		const LAYER_COUNT = 3;

		// テーマ別のカラーパレット
		const palettes = {
			dark: [205, 212, 218], // デニム寄りの青系
			light: [195, 210, 225], // 水色〜青系
		};

		// 現在のテーマ判定
		const getTheme = () =>
			document.documentElement.classList.contains("theme-dark")
			? "dark"
			: "light";

		const paintBackground = (theme) => {
			if (theme === "dark") {
				p.background(0, 0, 8);
			} else {
				p.background(0, 0, 100);
			}
		};

		const resetLayers = () => {
			const theme = getTheme();
			const colors = palettes[theme];
			layers.length = 0;
			paintBackground(theme);
			for (let i = 0; i < LAYER_COUNT; i++) {
				layers.push({
					hue: p.random(colors),
					yoff: p.random(1000),
					amp: p.random(100, 280),
					alpha: p.random(4, 12),
					speed: p.random(0.0001, 0.0002),
				});
			}
		};
		
		// 📱 高さを正しく取る関数（スマホ対応）
 		const getSafeHeight = () => window.visualViewport ? window.visualViewport.height : window.innerHeight;

		p.setup = () => {
			p.createCanvas(p.windowWidth, getSafeHeight());
			p.noStroke();
			p.colorMode(p.HSB, 360, 100, 100, 100);
			p.frameRate(30);
    		p.blendMode(p.BLEND);

			resetLayers();

			const themeObserver = new MutationObserver(resetLayers);
			themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
		};
		
		p.draw = () => {
			const theme = getTheme();
			const colors = palettes[theme];

			// 背景
			p.blendMode(p.MULTIPLY);
			if (theme === "dark") {
				p.fill(0, 0, 8, 10); // 深い黒寄り
			} else {
				p.fill(0, 0, 100, 10); // 白に近い
			}
			p.rect(0, 0, p.width, p.height);
			p.blendMode(p.BLEND);

			// 波レイヤー
			for (let l of layers) {
				// テーマに応じてランダムHueを設定（動的変化）
				if (p.frameCount % 300 === 0) {
					l.hue += 0.05; // 徐々に変化
					if (l.hue > 360) l.hue -= 360;
				}

				const hue = l.hue || p.random(colors);
				const sat = theme === "dark" ? 60 : 30;
				const bright = 50 + 20 * Math.sin(p.frameCount * 0.002); // 明るさゆっくり変化
				const alpha = l.alpha;

				p.fill(hue, sat, bright, alpha);

				p.beginShape();
				for (let x = 0; x <= p.width; x += 10) {
					const y =
					p.height / 2 +
					p.sin(x * 0.002 + l.yoff) * l.amp * 0.6 +
					p.noise(x * 0.002, p.frameCount * l.speed) * l.amp;
					p.vertex(x, y);
				}
				p.vertex(p.width, p.height);
				p.vertex(0, p.height);
				p.endShape(p.CLOSE);

				l.yoff += l.speed * 100;
			}

			p.noStroke();
			// 上部グラデーション（光の霞）
			const g = p.drawingContext.createLinearGradient(0, 0, 0, p.height);
			if (theme === "dark") {
				g.addColorStop(0, "hsla(210, 58%, 54%, 0.09)");
				g.addColorStop(1, "hsla(210, 60%, 5%, 0)");
			} else {
				g.addColorStop(0, "hsla(205, 90%, 95%, 0.1)");
				g.addColorStop(1, "hsla(215, 80%, 70%, 0)");
			}
			p.drawingContext.fillStyle = g;
			p.rect(0, 0, p.width, p.height);
		};

		// 📱 スマホのアドレスバー表示切替によるリサイズを無視してチラつきを防止
		let initialHeight = getSafeHeight();
		let resizeTimer = null;

		const resize = () => {
			clearTimeout(resizeTimer);
			resizeTimer = setTimeout(() => {
				const newW = window.innerWidth;
				const newH = getSafeHeight();
				const heightDiff = Math.abs(newH - p.height);
				const widthChanged = newW !== p.width;
				// 高さが150px未満の変化（アドレスバーの出入り）は無視する
				if (widthChanged || heightDiff > 150) {
					p.resizeCanvas(newW, newH);
				}
			}, 200);
		};

		p.windowResized = resize;
		if (window.visualViewport) {
			window.visualViewport.addEventListener("resize", resize);
		}
	};

	new p5(sketch, "p5-container");
</script>

<style>
	#p5-container {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}
	canvas {
		display: block;
		position: absolute;
		inset: 0;
		object-fit: cover;
		backface-visibility: hidden;
		transform: translateZ(0);
		will-change: transform;
	}
</style>
