---
interface Props {
	variant?: 'default' | 'tag' | 'badge';
}

const { variant = 'default' } = Astro.props;
---

<div class:list={['pill', variant === 'tag' && 'pill--tag', variant === 'badge' && 'pill--badge']}><slot /></div>

<style>
	.pill {
		display: flex;
		align-items: center;
		padding: 0.5rem 1rem;
		gap: 0.5rem;
		color: var(--accent-text-over);
		border: 1px solid var(--accent-regular);
		background-color: var(--accent-regular);
		border-radius: 999rem;
		font-size: var(--text-md);
		line-height: 1.35;
		white-space: nowrap;
	}

	/* Tag variant: looks like a label, not a button */
	.pill--tag {
		background-color: transparent;
		color: var(--gray-300);
		border-color: var(--gray-700);
		font-size: var(--text-sm);
		padding: 0.25rem 0.625rem;
		letter-spacing: 0.02em;
	}

	.pill--tag::before {
		content: '#';
		opacity: 0.5;
		font-weight: 600;
	}

	/* Badge variant: role label with icon, no '#', no button look */
	.pill--badge {
		background-color: transparent;
		color: var(--gray-200);
		border-color: var(--accent-dark);
		font-size: var(--text-sm);
		padding: 0.3rem 0.75rem;
		letter-spacing: 0.03em;
	}
</style>
