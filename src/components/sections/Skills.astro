---
const skillGroups = [
	{
		title: 'Frontend Web',
		items: ['React / Next.js / Astro'],
	},
	{
		title: 'Mobile',
		items: ['React Native (Expo)'],
	},
	{
		title: 'Backend / API',
		items: ['Firebase / Firestore', 'Cloud Run'],
	},
	{
		title: 'Infrastructure',
		items: ['Vercel'],
	},
	{
		title: 'Languages',
		items: ['TypeScript / JavaScript', 'Python', 'Swift'],
	},
];
---

<div class="skills-grid">
	{skillGroups.map((group) => (
		<div class="skill-group">
			<h3>{group.title}</h3>
			<ul>
				{group.items.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</div>
	))}
</div>

<style>
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 16px;
	}

	.skill-group h3 {
		font-size: var(--text-base);
		color: var(--gray-200);
		font-weight: 500;
	}

	.skill-group ul {
		padding-left: 16px;
	}

	.skill-group li {
		margin-bottom: 4px;
	}
</style>
