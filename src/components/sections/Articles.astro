---
// Component Imports
import Grid from '../ui/Grid.astro';
import ArticlePreview from '../cards/ArticlePreview.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('articles')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const articles = allArticles.slice(0, 3);
---

<section class="section with-background">
	<header class="section-header stack gap-2 lg:gap-4">
		<h3>Articles</h3>
	</header>

	<div class="gallery">
		<Grid>
			{
				articles.map((article) => (
					<li>
						<ArticlePreview article={article} />
					</li>
				))
			}
		</Grid>
	</div>

	{
		allArticles.length > 3 && (
			<footer class="section-footer">
				<a href="/articles" class="section-link">
					すべて見る
				</a>
			</footer>
		)
	}
</section>

<style>
	.section-footer {
		display: flex;
		justify-content: center;
		margin-top: 2rem;
	}

	.section-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.25rem;
		border: 1px solid var(--gray-800);
		border-radius: 999px;
		color: var(--gray-0);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 600;
		text-decoration: none;
		transition:
			color 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.section-link:hover,
	.section-link:focus-visible {
		border-color: var(--accent-regular);
		color: var(--accent-regular);
		transform: translateY(-1px);
	}
</style>