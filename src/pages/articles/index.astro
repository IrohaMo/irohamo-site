---
import { getCollection } from 'astro:content';

import ArticlePreview from '../../components/cards/ArticlePreview.astro';
import Grid from '../../components/ui/Grid.astro';
import Hero from '../../components/sections/Hero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('articles')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout title="Articles" description="記事一覧">
	<main class="wrapper stack gap-15 lg:gap-20">
		<section class="stack gap-8">
			<Hero title="Articles" tagline="" align="start" />
		</section>

		<section>
			<Grid>
				{
					articles.map((article) => (
						<li>
							<ArticlePreview article={article} />
						</li>
					))
				}
			</Grid>
		</section>
	</main>
</BaseLayout>

<style>
	.lead {
		max-width: 65ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}
</style>
