---
// Page section components
import ContactCTA from '../components/sections/ContactCTA.astro';
import Hero from '../components/sections/Hero.astro';
import Icon from '../components/ui/Icon.astro';

import About from '../components/sections/About.astro';
import Works from '../components/sections/Works.astro';
import Articles from '../components/sections/Articles.astro';
import Mentions from '../components/sections/Mentions.astro';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import XPostEmbed from '../components/embeds/XPostEmbed.astro';


import type { iconPaths } from '../components/ui/IconPaths';


const portrait="/assets/profile.jpeg";

const iconLinks: { label: string; href: string; icon: keyof typeof iconPaths }[] = [
  { label: 'GitHub', href: 'https://github.com/irohamo', icon: 'github-logo' },
  { label: 'Instagram', href: 'https://Instagram.com/irohamo.dev', icon: 'instagram-logo' },
];

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="irohamo.dev"
					tagline=""
					align="start"
				>
					<div class="roles">
						<span class="role"><Icon icon="code" size="1em" /> Developer</span>
						<span class="role"><Icon icon="shamisen-icon" size="1em" /> Shamisen</span>
					</div>
					<div class="socials">
						{iconLinks.map(({ href, icon, label }) => (
							<a href={href} class="social" target="_blank" rel="noopener noreferrer">
								<span class="sr-only">{label}</span>
								<Icon icon={icon} />
							</a>
						))}
					</div>
				</Hero>
				<Image
					src={portrait}
					alt="me holding the shamisen."
					width={480}
					height={620}
					loading="eager"
					format="webp"
					sizes="(max-width: 768px) 100vw, 480px"
				/>
			</header>
			<About />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
            <Works />
            <Articles />
			<Mentions />
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.role {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		color: var(--gray-300);
		font-size: var(--text-md);
	}

	.socials {
		display: none;
	}

	.social {
		display: flex;
		padding: 0.5rem;
		color: var(--gray-300);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.social:hover {
		color: var(--accent-regular);
	}

	.hero img {
		width: 100%;
		max-width: 320px;
		height: auto;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			display: flex;
			gap: 1.5rem;
		}

		.socials {
			display: flex;
			gap: 1rem;
			margin-top: -0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}
    
	.section {
		display: grid;
		gap: 2rem;
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}
	.mention-embed {
		max-width: 48rem;
		width: 100%;
		justify-self: center;
	}
</style>
