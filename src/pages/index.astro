---
import { getCollection } from 'astro:content';
// Component Imports
import ArticlePreview from '../components/cards/ArticlePreview.astro';
// Page section components
import ContactCTA from '../components/sections/ContactCTA.astro';
import Grid from '../components/ui/Grid.astro';
import Hero from '../components/sections/Hero.astro';
import Icon from '../components/ui/Icon.astro';

import About from '../components/sections/About.astro';
import PortfolioPreview from '../components/cards/PortfolioPreview.astro';
import HackathonPost from '../components/embeds/HackathonPost.astro';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';


// Content Fetching: List four most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

const articles = (await getCollection('article'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 3);

import type { iconPaths } from '../components/ui/IconPaths';


const portrait="/assets/profile.jpeg";

const iconLinks: { label: string; href: string; icon: keyof typeof iconPaths }[] = [
  { label: 'GitHub', href: 'https://github.com/IrohaMo', icon: 'github-logo' },
  { label: 'Instagram', href: 'https://Instagram.com/irohamo.dev', icon: 'instagram-logo' },
];

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="IrohaMo.dev"
					tagline=""
					align="start"
				>
					<div class="roles">
						<span class="role"><Icon icon="code" size="1em" /> Developer</span>
						<span class="role"><Icon icon="shamisen-icon" size="1em" /> Shamisen</span>
					</div>
					<div class="socials">
						{iconLinks.map(({ href, icon, label }) => (
							<a href={href} class="social" target="_blank" rel="noopener noreferrer">
								<span class="sr-only">{label}</span>
								<Icon icon={icon} />
							</a>
						))}
					</div>
				</Hero>
				<Image
					src={portrait}
					alt="me holding the shamisen."
					width={480}
					height={620}
					loading="eager"
					format="webp"
					sizes="(max-width: 768px) 100vw, 480px"
				/>
			</header>
			<About />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Works</h3>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>
			</section>

			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Articles</h3>
					<p>
						開発メモや制作記録をまとめる記事一覧です。
						<a href="/articles">すべて見る</a>
					</p>
				</header>

				<div class="gallery">
					<Grid>
						{
							articles.map((article) => (
								<li>
									<ArticlePreview article={article} />
								</li>
							))
						}
					</Grid>
				</div>
			</section>

			<section class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Mentions</h3>
				</header>

				<div class="gallery mention-embed">
					<HackathonPost />
				</div>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.role {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		color: var(--gray-300);
		font-size: var(--text-md);
	}

	.socials {
		display: none;
	}

	.social {
		display: flex;
		padding: 0.5rem;
		color: var(--gray-300);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.social:hover {
		color: var(--accent-regular);
	}

	.hero img {
		width: 100%;
		max-width: 320px;
		height: auto;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			display: flex;
			gap: 1.5rem;
		}

		.socials {
			display: flex;
			gap: 1rem;
			margin-top: -0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.mention-embed {
		max-width: 48rem;
		width: 100%;
		justify-self: center;
	}
</style>
